                    \\\"foreground\\\": \\\"#90e1ff\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Inline Code\\\",\\n                \\\"scope\\\": [\\n                    \\\"markup.raw.inline\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#f1e655\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Link Text\\\",\\n                \\\"scope\\\": [\\n                    \\\"string.other.link\\\",\\n                    \\\"punctuation.definition.string.end.markdown\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#ff5370\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Link URL\\\",\\n                \\\"scope\\\": [\\n                    \\\"meta.link\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#F77669\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Markup Quote\\\",\\n                \\\"scope\\\": [\\n                    \\\"markup.quote\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#F77669\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Separator\\\",\\n                \\\"scope\\\": [\\n                    \\\"meta.separator\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#d9f5dd\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Markup Inserted\\\",\\n                \\\"scope\\\": [\\n                    \\\"markup.inserted\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#f1e655\\\"\\n                }\\n            },\\n            {\\