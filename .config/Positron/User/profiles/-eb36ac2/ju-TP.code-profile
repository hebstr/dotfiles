{"name":"ju-TP","icon":"smiley","settings":"{\"settings\":\"{\\n\\n// ÉDITEUR ---------------------------------------------------------------------\\n\\n    \\\"editor.fontFamily\\\": \\\"'Fira Code', 'monospace'\\\",\\n    \\\"editor.fontSize\\\": 12,\\n    \\\"editor.fontLigatures\\\": true,\\n    \\\"editor.lineHeight\\\": 1.5,\\n    \\\"editor.detectIndentation\\\": true,\\n    \\\"editor.tabSize\\\": 4,\\n    \\\"editor.tabCompletion\\\": \\\"onlySnippets\\\",\\n    \\\"editor.formatOnSave\\\": false,\\n    \\\"editor.formatOnPaste\\\": false,\\n    \\\"editor.renderFinalNewline\\\": \\\"dimmed\\\",\\n    \\\"editor.actionBar.enabled\\\": false,\\n    \\\"editor.cursorBlinking\\\": \\\"phase\\\",\\n    \\\"editor.cursorStyle\\\": \\\"line\\\",\\n    \\\"editor.cursorWidth\\\": 3,\\n    \\\"editor.cursorSurroundingLines\\\": 10,\\n    \\\"notebook.lineNumbers\\\": \\\"on\\\",\\n\\n    \\\"editor.rulers\\\": [\\n        {\\n            \\\"column\\\": 80\\n        },\\n        {\\n            \\\"color\\\": \\\"#ff0000\\\",\\n            \\\"column\\\": 100\\n        }\\n    ],\\n\\n// GESTION DES FICHIERS --------------------------------------------------------\\n\\n    \\\"files.defaultLanguage\\\": \\\"r\\\",\\n    \\\"files.insertFinalNewline\\\": true,\\n    \\\"files.trimFinalNewlines\\\": true,\\n    \\\"files.trimTrailingWhitespace\\\": true,\\n    \\\"files.associations\\\": {\\n        \\\"renv.lock\\\": \\\"json\\\"\\n    },\\n\\n// EXCLUSIONS DE FICHIERS ------------------------------------------------------\\n\\n    \\\"files.exclude\\\": {\\n        \\\"**/.Rhistory\\\": true,\\n        \\\"**/*.Rproj\\\": true,\\n        \\\"**/.Rproj.user\\\": true,\\n        \\\"**/renv/library\\\": true,\\n        \\\"**/renv/local\\\": true,\\n        \\\"**/renv/sandbox\\\": true,\\n        \\\"**/renv/staging\\\": true,\\n        \\\"**/.quarto\\\": true,\\n        \\\"**/_book\\\": true,\\n        \\\"**/_site\\\": true,\\n        \\\"**/_freeze\\\": true,\\n        \\\"**/.venv\\\": true\\n    },\\n\\n    \\\"files.watcherExclude\\\": {\\n        \\\"**/.Rhistory\\\": true,\\n        \\\"**/.Rproj.user\\\": true,\\n        \\\"**/renv/library\\\": true,\\n        \\\"**/renv/local\\\": true,\\n        \\\"**/renv/sandbox\\\": true,\\n        \\\"**/renv/staging\\\": true,\\n        \\\"**/.quarto\\\": true,\\n        \\\"**/_book\\\": true,\\n        \\\"**/_site\\\": true,\\n        \\\"**/_freeze\\\": true,\\n        \\\"**/.venv\\\": true\\n    },\\n\\n    \\\"search.exclude\\\": {\\n        \\\"**/.Rhistory\\\": true,\\n        \\\"**/.Rproj.user\\\": true,\\n        \\\"**/renv/library\\\": true,\\n        \\\"**/renv/local\\\": true,\\n        \\\"**/renv/sandbox\\\": true,\\n        \\\"**/renv/staging\\\": true,\\n        \\\"**/.quarto\\\": true,\\n        \\\"**/_book\\\": true,\\n        \\\"**/_site\\\": true,\\n        \\\"**/_freeze\\\": true,\\n        \\\"**/.venv\\\": true\\n    },\\n\\n// LANGAGE SPÉCIFIQUE ----------------------------------------------------------\\n\\n    \\\"[r]\\\": {\\n        \\\"editor.tabSize\\\": 2\\n    },\\n\\n    \\\"[markdown]\\\": {\\n        \\\"files.trimTrailingWhitespace\\\": false\\n    },\\n\\n    \\\"[quarto]\\\": {\\n        \\\"files.trimTrailingWhitespace\\\": false,\\n        // \\\"editor.wordWrap\\\": \\\"off\\\"\\n    },\\n\\n    \\\"quarto.render.previewType\\\": \\\"external\\\",\\n    \\\"python.installModulesInTerminal\\\": true,\\n    \\\"python.globalModuleInstallation\\\": true,\\n    \\\"python.enableAutoReload\\\": false,\\n    \\\"positronPythonPackageManager.enablePackagePane\\\": true,\\n    // \\\"python.terminal.activateEnvironment\\\": false,\\n\\n// GIT -------------------------------------------------------------------------\\n\\n    \\\"git.openRepositoryInParentFolders\\\": \\\"always\\\",\\n    \\\"git.autoRepositoryDetection\\\": false,\\n    \\\"git.enableCommitSigning\\\": true,\\n\\n    \\\"projectManager.git.baseFolders\\\": [\\n        \\\"/home/julien\\\"\\n    ],\\n\\n// TERMINAL --------------------------------------------------------------------\\n\\n    \\\"terminal.integrated.fontFamily\\\": \\\"'Fira Code', 'monospace'\\\",\\n    \\\"terminal.integrated.fontSize\\\": 12,\\n    \\\"terminal.integrated.fontLigatures.enabled\\\": true,\\n    \\\"terminal.integrated.cursorBlinking\\\": true,\\n    \\\"terminal.integrated.cursorStyle\\\": \\\"line\\\",\\n    \\\"terminal.integrated.cursorWidth\\\": 3,\\n    \\\"terminal.integrated.cursorStyleInactive\\\": \\\"line\\\",\\n    \\\"terminal.integrated.stickyScroll.enabled\\\": false,\\n    \\\"terminal.integrated.environmentChangesRelaunch\\\": \\\"off\\\",\\n    // \\\"terminal.integrated.shellIntegration.enabled\\\": false,\\n\\n// INTERFACE -------------------------------------------------------------------\\n\\n    \\\"explorer.confirmDragAndDrop\\\": false,\\n    \\\"explorer.confirmDelete\\\": false,\\n    \\\"extensions.autoRestart\\\": true,\\n    \\\"testing.resultsView.layout\\\": \\\"treeLeft\\\",\\n\\n// POSITRON --------------------------------------------------------------------\\n\\n    \\\"console.fontFamily\\\": \\\"'Fira Code', 'monospace'\\\",\\n    \\\"console.fontSize\\\": 12.5,\\n    \\\"console.fontLigatures\\\": true,\\n    \\\"debug.console.fontSize\\\": 11,\\n\\n    \\\"positron-r-package-manager.defaultInstaller\\\": \\\"pak\\\",\\n    \\\"positron.r.quietMode\\\": true,\\n    \\\"positron.assistant.enable\\\": false,\\n    \\\"positron.plots.darkFilter\\\": \\\"off\\\",\\n    \\\"positron.viewer.openLocalhostUrls\\\": false,\\n\\n// EXTENSIONS ------------------------------------------------------------------\\n\\n    \\\"errorLens.delay\\\": 500,\\n    \\\"errorLens.padding\\\": \\\"0px\\\",\\n\\n    \\\"material-icon-theme.files.associations\\\": {\\n        \\\".Rprofile\\\": \\\"r\\\",\\n        \\\".Renviron\\\": \\\"r\\\",\\n        \\\"DESCRIPTION\\\": \\\"r\\\",\\n        \\\"NAMESPACE\\\": \\\"r\\\",\\n        \\\"_targets.R\\\": \\\"r\\\",\\n        \\\".Rbuildignore\\\": \\\"settings\\\",\\n        \\\"renv.lock\\\": \\\"lock\\\",\\n        \\\"rv.lock\\\": \\\"lock\\\",\\n    },\\n\\n    \\\"material-icon-theme.folders.associations\\\": {\\n        \\\"man\\\": \\\"docs\\\",\\n        \\\"vignettes\\\": \\\"docs\\\",\\n        \\\"renv\\\": \\\"lib\\\",\\n    },\\n\\n    \\\"quartoWizard.ask.trustAuthors\\\": \\\"never\\\",\\n\\n// RÉSEAU ET CONTENEURS --------------------------------------------------------\\n\\n    \\\"json.schemaDownload.enable\\\": false,\\n    \\\"remote.autoForwardPortsSource\\\": \\\"hybrid\\\",\\n\\n// CLAUDE CODE -----------------------------------------------------------------\\n\\n    \\\"claudeCode.preferredLocation\\\": \\\"panel\\\",\\n    \\\"claudeCode.selectedModel\\\": \\\"opus\\\",\\n\\n// APPARENCE GLOBALE -----------------------------------------------------------\\n\\n    \\\"workbench.colorTheme\\\": \\\"Material Night Purple\\\",\\n    \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\n    \\\"workbench.settings.editor\\\": \\\"json\\\",\\n    \\\"workbench.editor.highlightModifiedTabs\\\": true,\\n    \\\"workbench.editor.enablePreview\\\": false,\\n    \\\"workbench.editor.empty.hint\\\": \\\"hidden\\\",\\n    \\\"workbench.tree.renderIndentGuides\\\": \\\"always\\\",\\n    \\\"workbench.secondarySideBar.showLabels\\\": false,\\n\\n    \\\"window.title\\\": \\\"${activeEditorFull}${separator}${rootName}\\\",\\n\\n    \\\"window.zoomLevel\\\": 0.1,\\n\\n// COLORATION SYNTAXIQUE -------------------------------------------------------\\n\\n    \\\"editor.tokenColorCustomizations\\\": {\\n        \\\"textMateRules\\\": [\\n            {\\n                \\\"name\\\": \\\"Text and Source Base\\\",\\n                \\\"scope\\\": [\\n                    \\\"text\\\",\\n                    \\\"source\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#CDD3DE\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Variable\\\",\\n                \\\"scope\\\": [\\n                    \\\"variable\\\",\\n                    \\\"variable.parameter\\\",\\n                    \\\"source.python\\\",\\n                    \\\"source.python meta.function-call.arguments.python\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#ffffff\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Constant Numeric\\\",\\n                \\\"scope\\\": [\\n                    \\\"constant.numeric\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#ff7869\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Constant Language\\\",\\n                \\\"scope\\\": [\\n                    \\\"constant.language\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#ffbc6a\\\",\\n                    \\\"fontStyle\\\": \\\"bold\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Constant Other\\\",\\n                \\\"scope\\\": [\\n                    \\\"constant\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#F77669\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"String\\\",\\n                \\\"scope\\\": [\\n                    \\\"string\\\",\\n                    \\\"constant.other.symbol\\\",\\n                    \\\"entity.other.inherited-class\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#c5ff93\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Punctuation Separator / Operator\\\",\\n                \\\"scope\\\": [\\n                    \\\"punctuation.separator.arguments.python\\\",\\n                    \\\"punctuation.separator.element.python\\\",\\n                    \\\"punctuation.separator.period.python\\\",\\n                    \\\"keyword.operator\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#a2fff6\\\",\\n                    \\\"fontStyle\\\": \\\"\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Keyword\\\",\\n                \\\"scope\\\": [\\n                    \\\"keyword\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#d08aff\\\",\\n                    \\\"fontStyle\\\": \\\"bold\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Storage\\\",\\n                \\\"scope\\\": [\\n                    \\\"storage\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#d08aff\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Function\\\",\\n                \\\"scope\\\": [\\n                    \\\"entity.name.function\\\",\\n                    \\\"meta.function-call support.type\\\",\\n                    \\\"meta.function-call support.function\\\",\\n                    \\\"meta.function-call.generic\\\",\\n                    \\\"support.function\\\",\\n                    \\\"keyword.other.special-method\\\",\\n                    \\\"variable.function\\\"\\n                ],\\n                \\\"settings\\\": {\\n                    \\\"foreground\\\": \\\"#90e1ff\\\"\\n                }\\n            },\\n            {\\n                \\\"name\\\": \\\"Punctuation Definition\\\",\\n                \\\"scope\\\": [\\n                    \\\"punctuation.definition.string\\\",\\n        