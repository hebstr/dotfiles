{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "85"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash",
      "Write(/home/julien/.claude/skills/**)",
      "Write(/tmp/**)"
    ],
    "deny": [
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(git checkout*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git tag*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(rm -rf*)"
    ]
  },
  "enabledPlugins": {
    "posit-dev@posit-dev-skills": true,
    "r-lib@posit-dev-skills": true,
    "open-source@posit-dev-skills": true,
    "quarto@posit-dev-skills": true,
    "skill-creator@claude-plugins-official": true,
    "ouroboros@ouroboros": true
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/inject-project-context.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Claude Code needs your attention'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Check if the task is fully complete. Verify that all files mentioned as created or modified actually exist and are non-empty. If something is missing or incomplete, return {\"ok\": false, \"reason\": \"what's missing\"}.",
            "model": "claude-haiku"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "ouroboros": {
      "source": {
        "source": "github",
        "repo": "Q00/ouroboros"
      }
    }
  },
  "effortLevel": "medium"
}
